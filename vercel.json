{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3",
      "maxDuration": 30
    },
    "api/inicio.php": {
      "runtime": "vercel-php@0.7.3",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/(.*\\.php)$", "dest": "/api/index.php" },
    { "handle": "filesystem" },
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "env": {
    "CAFETIN_DB_DRIVER": "sqlite",
    "CAFETIN_SQLITE_PATH": "/tmp/cafetin.db"
  }
}
